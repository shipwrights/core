{
	"$schema": "http://json-schema.org/draft-07/schema#",
	"$id": "https://github.com/shipwrights/core/schemas/shipwrights-config.schema.json",
	"title": "Shipwrights config",
	"description": "Schema for .shipwrights.yml — the per-project orchestration config.",
	"type": "object",
	"required": [
		"version",
		"branches",
		"roles",
		"pipeline",
		"backlog",
		"verify",
		"merge"
	],
	"additionalProperties": false,
	"properties": {
		"version": {
			"description": "Config schema version. Used by /shipwrights-upgrade migrations.",
			"type": "integer",
			"minimum": 1
		},

		"project": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"name": { "type": "string" },
				"languages": {
					"type": "array",
					"items": { "type": "string" }
				}
			}
		},

		"branches": {
			"type": "object",
			"required": ["integration", "release", "patterns"],
			"additionalProperties": false,
			"properties": {
				"integration": { "type": "string", "default": "dev" },
				"release": { "type": "string", "default": "main" },
				"patterns": {
					"type": "object",
					"required": ["feature", "fix", "chore", "scratch"],
					"additionalProperties": false,
					"properties": {
						"feature": { "type": "string" },
						"fix": { "type": "string" },
						"chore": { "type": "string" },
						"scratch": { "type": "string" }
					}
				}
			}
		},

		"scratch": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"push_to_remote": { "type": "boolean", "default": false },
				"bundle_on_failure": { "type": "boolean", "default": true },
				"cleanup_on_integrate": { "type": "boolean", "default": true }
			}
		},

		"roles": {
			"type": "array",
			"minItems": 1,
			"items": { "$ref": "#/definitions/role" }
		},

		"pipeline": {
			"type": "array",
			"minItems": 1,
			"items": { "$ref": "#/definitions/stage" }
		},

		"tier_routing": {
			"type": "array",
			"items": { "$ref": "#/definitions/tierRule" }
		},

		"tiers": {
			"type": "object",
			"additionalProperties": { "$ref": "#/definitions/tierDef" }
		},

		"backlog": {
			"type": "object",
			"required": ["source"],
			"additionalProperties": false,
			"properties": {
				"source": { "$ref": "#/definitions/sourceRef" },
				"state_dir": { "type": "string", "default": "docs/backlog/epics" }
			}
		},

		"verify": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"detected": {
					"type": "object",
					"additionalProperties": { "type": "string" }
				},
				"overrides": {
					"type": "object",
					"additionalProperties": { "type": "string" }
				}
			}
		},

		"guards": {
			"type": "array",
			"items": { "$ref": "#/definitions/guard" }
		},

		"merge": {
			"type": "object",
			"required": ["strategy"],
			"additionalProperties": false,
			"properties": {
				"strategy": {
					"enum": ["rebase", "squash", "merge"],
					"default": "rebase"
				},
				"stack_depth": { "type": "integer", "minimum": 1, "default": 3 },
				"auto_merge_labels": { "type": "array", "items": { "type": "string" } },
				"block_label": { "type": "string" }
			}
		},

		"loop": {
			"type": "object",
			"additionalProperties": false,
			"description": "Behaviour for /shipwrights-loop. Defaults are safe — opt in to auto_merge explicitly.",
			"properties": {
				"auto_merge": {
					"type": "boolean",
					"default": false,
					"description": "When true, /shipwrights-loop calls `gh pr merge --auto --squash` on each PR it opens (after a one-time typed confirmation per loop). Branch-protection rules still apply. Default false."
				},
				"poll_interval_seconds": {
					"type": "integer",
					"minimum": 10,
					"default": 30,
					"description": "How often /shipwrights-loop polls `gh pr view` for merge state during the awaiting_merge phase."
				},
				"stuck_pr_hours": {
					"type": "integer",
					"minimum": 1,
					"default": 24,
					"description": "If a PR sits OPEN this long with no merge progress, escalate to the user."
				}
			}
		},

		"lock": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"kind": {
					"enum": ["markdown", "github-issues", "custom"],
					"default": "markdown"
				},
				"config": { "type": "object" }
			}
		},

		"telemetry": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"enabled": { "type": "boolean", "default": true },
				"log_path": {
					"type": "string",
					"default": ".shipwrights/telemetry.jsonl"
				},
				"budget_per_epic_tokens": { "type": "integer", "minimum": 0 },
				"on_budget_exceeded": {
					"enum": ["warn", "escalate", "abort"],
					"default": "warn"
				}
			}
		},

		"spec": {
			"description": "Configuration for /shipwrights-spec — the spec-first single-task pipeline.",
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"enabled": { "type": "boolean", "default": true },
				"output_dir": { "type": "string", "default": "docs/backlog/specs" },
				"context_depth": {
					"enum": ["shallow", "medium", "deep"],
					"default": "medium"
				},
				"enforcement": { "enum": ["strict", "loose"], "default": "strict" },
				"approval_required": { "type": "boolean", "default": true }
			}
		},

		"hard_rules": {
			"type": "array",
			"items": { "type": "string" }
		},

		"extends": {
			"description": "Optional path to a parent config to inherit from.",
			"type": "string"
		}
	},

	"definitions": {
		"role": {
			"type": "object",
			"required": ["name", "agent"],
			"additionalProperties": false,
			"properties": {
				"name": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
				"description": { "type": "string" },
				"agent": { "$ref": "#/definitions/agentRef" },
				"capabilities": { "$ref": "#/definitions/capabilities" },
				"invoke_at": { "type": "array", "items": { "type": "string" } },
				"parallel_with": { "type": "array", "items": { "type": "string" } }
			}
		},

		"agentRef": {
			"oneOf": [
				{ "const": "bundled" },
				{
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"ref": { "const": "bundled" }
					},
					"required": ["ref"]
				},
				{
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"user": { "type": "string" }
					},
					"required": ["user"]
				},
				{
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"custom": { "type": "string" }
					},
					"required": ["custom"]
				},
				{
					"type": "object",
					"additionalProperties": false,
					"properties": {
						"npm": { "type": "string" }
					},
					"required": ["npm"]
				}
			]
		},

		"capabilities": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"can_write": {
					"oneOf": [
						{ "type": "boolean" },
						{ "enum": ["tests-only", "fixup-only"] }
					]
				},
				"can_browse": { "type": "boolean" },
				"scope": { "type": "array", "items": { "type": "string" } },
				"escalate_on": { "type": "array", "items": { "type": "string" } }
			}
		},

		"stage": {
			"type": "object",
			"required": ["stage", "owner"],
			"additionalProperties": false,
			"properties": {
				"stage": { "type": "string", "pattern": "^[a-z][a-z0-9-]*$" },
				"owner": { "type": "array", "items": { "type": "string" } },
				"inputs": { "type": "array", "items": { "type": "string" } },
				"outputs": { "type": "array", "items": { "type": "string" } },
				"optional_when": { "type": "string" },
				"requires": { "type": "string" },
				"parallelism": {
					"enum": ["full", "sequential", "none"],
					"default": "sequential"
				},
				"integrate_order": { "type": "array", "items": { "type": "string" } },
				"on_conflict": {
					"enum": ["escalate", "auto-rebase"],
					"default": "escalate"
				},
				"on_specialist_failure": {
					"enum": ["escalate", "bundle-and-escalate", "retry"],
					"default": "bundle-and-escalate"
				},
				"on_scope_violation": {
					"enum": ["escalate", "warn"],
					"default": "escalate"
				},
				"freeze_paths": { "type": "array", "items": { "type": "string" } },
				"write_mode": { "enum": ["full", "fixup-only", "none"] },
				"skill": {
					"type": "string",
					"description": "Override the bundled stage skill with a custom one."
				}
			}
		},

		"tierRule": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"if": { "type": "string" },
				"tier": { "type": "string" },
				"default": { "type": "string" }
			}
		},

		"tierDef": {
			"type": "object",
			"additionalProperties": false,
			"properties": {
				"skip_stages": { "type": "array", "items": { "type": "string" } },
				"optional_stages": { "type": "array", "items": { "type": "string" } },
				"auto_merge": { "type": "boolean", "default": false }
			}
		},

		"sourceRef": {
			"type": "object",
			"required": ["kind"],
			"properties": {
				"kind": { "type": "string" },
				"config": { "type": "object" }
			}
		},

		"guard": {
			"type": "object",
			"required": ["name"],
			"additionalProperties": false,
			"properties": {
				"name": { "type": "string" },
				"enabled": { "type": "boolean", "default": true },
				"rules": { "type": "array" },
				"config": { "type": "object" },
				"runs": { "$ref": "#/definitions/guardRun" },
				"on_violation": {
					"enum": ["block", "warn", "escalate"],
					"default": "block"
				},
				"stages": {
					"type": "array",
					"items": { "type": "string" },
					"description": "Stages where this guard runs. Default: before-integrate, before-ship."
				}
			}
		},

		"guardRun": {
			"oneOf": [
				{
					"type": "object",
					"additionalProperties": false,
					"properties": { "shell": { "type": "string" } },
					"required": ["shell"]
				},
				{
					"type": "object",
					"additionalProperties": false,
					"properties": { "npm": { "type": "string" } },
					"required": ["npm"]
				},
				{
					"type": "object",
					"additionalProperties": false,
					"properties": { "bundled": { "type": "string" } },
					"required": ["bundled"]
				}
			]
		}
	}
}
